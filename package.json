{
  "name": "telyx",
  "version": "1.1.0",
  "description": "Lightweight telemetry for AI agents — zero dependencies, native fetch, plug-and-play observability for LLM-powered apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test test/telyx.test.mjs test/anomaly-detection.test.mjs",
    "test:watch": "node --test --watch test/telyx.test.mjs test/anomaly-detection.test.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "example": "node examples/basic-usage.js"
  },
  "keywords": [
    "telemetry",
    "monitoring",
    "ai",
    "agent",
    "analytics",
    "performance",
    "observability",
    "logging",
    "tracking"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/telyx.git"
  },
  "bugs": {
    "url": "https://github.com/sulthonzh/telyx/issues"
  },
  "homepage": "https://github.com/sulthonzh/telyx#readme",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.19.42",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

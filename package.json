{
  "name": "telyx",
  "version": "1.44.0",
  "description": "Lightweight telemetry for AI agents — zero dependencies, native fetch, plug-and-play observability for LLM-powered apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test test/telyx.test.mjs test/anomaly-detection.test.mjs test/branch-coverage.test.mjs",
    "test:watch": "node --test --watch test/telyx.test.mjs test/anomaly-detection.test.mjs test/branch-coverage.test.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test && npm run lint",
    "example": "node examples/basic-usage.js",
    "lint": "eslint src/",
    "test:coverage": "c8 node --test test/telyx.test.mjs test/anomaly-detection.test.mjs"
  },
  "keywords": [
    "telemetry",
    "monitoring",
    "ai",
    "agent",
    "analytics",
    "performance",
    "observability",
    "logging",
    "tracking"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/telyx.git"
  },
  "bugs": {
    "url": "https://github.com/sulthonzh/telyx/issues"
  },
  "homepage": "https://github.com/sulthonzh/telyx#readme",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.0",
    "@types/node": "^20.19.42",
    "c8": "^11.0.0",
    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "c8": {
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "dist/**/*.test.js",
      "dist/**/*.map"
    ],
    "reporter": [
      "text",
      "text-summary",
      "lcov"
    ]
  }
}

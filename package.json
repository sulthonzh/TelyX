{
  "name": "telyx",
  "version": "1.0.0",
  "description": "A lightweight telemetry system for AI agents and intelligent workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test test/telyx.test.mjs",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "example": "node examples/basic-usage.js"
  },
  "keywords": [
    "telemetry",
    "monitoring",
    "ai",
    "agent",
    "analytics",
    "performance",
    "observability",
    "logging",
    "tracking"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/telyx.git"
  },
  "bugs": {
    "url": "https://github.com/sulthonzh/telyx/issues"
  },
  "homepage": "https://github.com/sulthonzh/telyx#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.42",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
